# Local development only. Copy this file to .env and change values as needed.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
API_HTTP_PORT=8080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clean_api_starter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-only
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=clean_api_starter;Username=postgres;Password=change-me-local-only

Jwt__Issuer=CleanApiStarter
Jwt__Audience=CleanApiStarter.Client
Jwt__Secret=change-this-local-jwt-secret-at-least-32-characters
Jwt__ExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=7

Seed__SuperAdminEmail=admin@example.com
Seed__SuperAdminPassword=ChangeMe123!
Seed__UserEmail=user@example.com
Seed__UserPassword=ChangeMe123!
